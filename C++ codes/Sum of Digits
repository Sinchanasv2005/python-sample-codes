#include <iostream>
using namespace std;

int main() {
    int number, sum = 0;
    cout << "Enter a number: ";
    cin >> number;
    
    // Make a copy of number to work with positive digits only
    int temp = number;
    
    while (temp > 0) {
        int digit = temp % 10;  // Get the last digit
        sum = sum + digit;      // Add digit to sum
        temp = temp / 10;       // Remove the last digit
    }

    cout << "Sum of digits of " << number << " is " << sum << endl;
    return 0;
}
